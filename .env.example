# ── Frontend (baked into JS bundle at build time) ──────────────────────────────
# Set to your server's public IP or domain before running docker compose build
VITE_API_URL=http://YOUR_SERVER_IP:8888

# ── Backend ────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-64-char-hex-string

# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=http://YOUR_SERVER_IP:3200,http://localhost:3200

# ── Data paths (backend container) ─────────────────────────────────────────────
# Change UPLOAD_DIR to a NAS or host path without touching any code — then rebuild
DATABASE_PATH=/data/signage.db
UPLOAD_DIR=/data/uploads
