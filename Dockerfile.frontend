FROM node:18-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy the rest of the application
COPY . .

# Pass the backend URL during the build stage
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

# Build the app
RUN npm run build

EXPOSE 3200

# Serve the built app using vite preview, exposing it on port 3200
CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "3200"]
